generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Post {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  content     String
  publishedAt DateTime @default(now())
  views       Int      @default(0)
  tags        String[]
}

model Project {
  id          String   @id @default(cuid())
  name        String
  description String
  imageUrl    String
  link        String?
  techStack   String[]
  featured    Boolean  @default(false)
}
